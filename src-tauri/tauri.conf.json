{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Beehive",
  "version": "0.1.4",
  "identifier": "com.beehive.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Beehive",
        "width": 1400,
        "height": 900
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "signingIdentity": "Developer ID Application: Mykyta Storozhenko (QB9BZ77543)",
      "hardenedRuntime": true,
      "minimumSystemVersion": "10.13"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEIwMTRDQTZERjU4RUFDODEKUldTQnJJNzFiY29Vc0hERzFRU3JINnpRSGgxZWo2NG9FYURsZ2EzSEwwVHc0NVJLOSsrWlVSeEUK",
      "endpoints": [
        "https://github.com/storozhenko98/beehive/releases/latest/download/latest.json"
      ]
    }
  }
}
